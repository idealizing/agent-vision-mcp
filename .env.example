# VLM Provider - OpenAI-compatible
VISION_API_KEY=
VISION_BASE_URL=https://api.example.com/v1
VISION_MODEL_ID=glm-4v-flash

# OCR Provider
OCR_ENABLED=false
OCR_API_KEY=
OCR_BASE_URL=
OCR_MODEL_ID=DeepSeek-OCR

# Runtime
VISION_TIMEOUT=60
VISION_MAX_RETRIES=3
VISION_DEFAULT_DETAIL=auto
VISION_SUPPORTS_IMAGE_DETAIL=false
# auto: analyze/compare URLs are passed through; pixel-based tools download them
VISION_URL_MODE=auto

# Input limits
VISION_MAX_IMAGE_SIZE_MB=10
VISION_MAX_IMAGE_PIXELS=40000000
VISION_MAX_BATCH_IMAGES=10

# Security
VISION_ALLOW_LOCAL_FILES=true
VISION_ALLOWED_PATHS=/data,/tmp
VISION_BLOCK_PRIVATE_IPS=true

# Transport
VISION_TRANSPORT=stdio
