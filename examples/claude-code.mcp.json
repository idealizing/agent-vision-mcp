{
  "mcpServers": {
    "agent-vision": {
      "type": "stdio",
      "command": "uvx",
      "args": ["agent-vision-mcp"],
      "env": {
        "UV_DEFAULT_INDEX": "https://pypi.org/simple",
        "VISION_API_KEY": "${VISION_API_KEY}",
        "VISION_BASE_URL": "${VISION_BASE_URL}",
        "VISION_MODEL_ID": "${VISION_MODEL_ID}",
        "VISION_URL_MODE": "auto",
        "VISION_TRANSPORT": "stdio"
      }
    }
  }
}
